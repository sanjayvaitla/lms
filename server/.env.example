# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vtricks_lms"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-me-to-a-random-64-char-secret"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-secret"
JWT_ACCESS_EXPIRY="1h"
JWT_REFRESH_EXPIRY="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ─── AWS S3 (optional — remove/leave blank to use local disk storage) ─────────
# Create an S3 bucket and IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
# Optional: CloudFront or custom domain in front of S3
# AWS_S3_CUSTOM_DOMAIN="https://cdn.yourdomain.com"

# ─── Google OAuth (optional — leave blank to disable) ─────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:5000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/auth/google/callback"
# Frontend URL — used to redirect after successful Google login
CLIENT_URL="http://localhost:5173"

# ─── MSG91 OTP / MFA (optional — leave blank to disable) ──────────────────────
# Sign up at https://msg91.com → get API key from your dashboard
# Register your sender ID + OTP template with DLT (mandatory in India)
MSG91_API_KEY=""
MSG91_SENDER_ID="VTRLMS"
MSG91_TEMPLATE_ID=""
# OTP expiry in minutes (default 10)
OTP_EXPIRY_MINUTES=10
